# Rust build artifacts (app/target reaches ~12G after an aptos-core build)
/target
/app/target

# Move compiler output — regenerated by `aptos move compile`
/fixtures/*/build

# Aptos CLI local config (may contain private keys)
.aptos

# Reports and logs produced by running the profiler
*.log
/reports

# OS and editor cruft
.DS_Store
*.swp
.idea/
.vscode/
